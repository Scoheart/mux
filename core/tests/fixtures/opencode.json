{
  "$schema": "https://opencode.ai/config.json",
  "model": "provider/private-model",
  "mcp": {
    "local-tools": {
      "type": "local",
      "command": ["npx", "-y", "old-server"],
      "environment": { "TOKEN": "local-secret" },
      "cwd": "/private/worktree",
      "enabled": false,
      "timeout": 9000
    },
    "remote-tools": {
      "type": "remote",
      "url": "https://old.example.com/mcp",
      "oauth": false,
      "enabled": true
    }
  }
}
