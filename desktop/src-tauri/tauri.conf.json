{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MUX",
  "version": "1.2.6",
  "identifier": "com.scoheart.mux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && bash scripts/prepare-sidecar.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MUX",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/scoheart/mux/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5MDEzRENBRDAyRTM5RjUKUldUMU9TN1F5ajBCK1VXdElRYzcxb0ZrR3ZkVWN6VTNBUCt0T2NubEoxdW1UaWt1aFR3WFBraHUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    },
    "externalBin": ["binaries/mux"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
